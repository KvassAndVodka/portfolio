# Database and authentication
DATABASE_URL=postgresql://postgres:password@postgres:5432/portfolio
POSTGRES_PASSWORD=change-me
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
ANALYTICS_HASH_SECRET=replace-with-a-separate-long-random-secret
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Local-only admin preview. Ignored in production even when set to true.
DEV_ADMIN_BYPASS=false

# Contact form email delivery (Resend)
RESEND_API_KEY=re_xxxxxxxxx
CONTACT_TO_EMAIL=javier.raut@gmail.com
CONTACT_FROM_EMAIL=Portfolio <contact@your-verified-domain.com>

# Optional Tailscale deployment
TS_AUTHKEY=
